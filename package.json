{
  "name": "astroship-11ty",
  "version": "1.0.0",
  "description": "Astroship website built with 11ty and Tailwind CSS",
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:11ty": "eleventy --serve --watch",
    "dev:css": "tailwindcss -i ./src/assets/css/styles.css -o ./_site/assets/css/styles.css --watch",
    "build": "npm-run-all build:css build:11ty",
    "build:11ty": "eleventy",
    "build:css": "tailwindcss -i ./src/assets/css/styles.css -o ./_site/assets/css/styles.css --minify",
    "clean": "rm -rf _site"
  },
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "@tailwindcss/typography": "^0.5.13",
    "autoprefixer": "^10.4.19",
    "dotenv": "^17.3.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3"
  }
}
