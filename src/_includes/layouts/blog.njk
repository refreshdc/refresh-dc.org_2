---
layout: layouts/base.njk
---

<section>
  <div class="max-w-screen-xl mx-auto px-5">
    <div class="mx-auto max-w-[735px] mt-14">
      <span class="text-blue-400 uppercase tracking-wider text-sm font-medium">
        {{ category }}
      </span>
      <h1 class="text-4xl lg:text-5xl font-bold lg:tracking-tight mt-1 lg:leading-tight">
        {{ title }}
      </h1>
      <div class="flex gap-2 mt-3 items-center flex-wrap md:flex-nowrap">
        <span class="text-gray-400">
          {{ author }}
        </span>
        <span class="text-gray-400">&bull;</span>
        <time class="text-gray-400" datetime="{{ publishDate | isoDate }}">
          {{ publishDate | formatDate }}
        </time>
        <span class="text-gray-400 hidden md:block">&bull;</span>
        <div class="w-full md:w-auto flex flex-wrap gap-3">
          {% for tag in tags %}
            <span class="text-sm text-gray-500">#{{ tag }}</span>
          {% endfor %}
        </div>
      </div>
    </div>

    <div class="mx-auto prose prose-lg mt-6 max-w-[735px]">
      {{ content | safe }}
    </div>

    <div class="text-center mt-8">
      <a href="/blog/" class="bg-gray-100 px-5 py-3 rounded-md hover:bg-gray-200 transition">
        &larr; Back to Blog
      </a>
    </div>
  </div>
</section>
