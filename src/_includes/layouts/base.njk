          api_host: 'https://us.i.posthog.com',
          defaults: '2026-05-30',
          person_profiles: 'identified_only',
      })
    </script>
    {% endif %}
  </head>
  <body  >
    {% include "components/navbar.njk" %}
    <main>
      {{ content | safe }}
    </main>
    {% include "components/footer.njk" %}
  </body>
</html>
