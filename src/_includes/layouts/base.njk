<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content="Eleventy" />

    {% set pageTitle = title + " | " + site.name if title else "Refresh DC — DC's Creative & Tech Community Since 2006" %}
    {% set pageDescription = description or site.description %}
    <title>{{ pageTitle }}</title>
    <meta name="description" content="{{ pageDescription }}" />
    <meta name="keywords" content="Refresh DC, DC creative community, Washington DC meetups, design community, tech community, creative technology, networking events, workshops, talks" />
    <meta name="author" content="Refresh DC" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:title" content="{{ pageTitle }}" />
    <meta property="og:description" content="{{ pageDescription }}" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
    <meta property="og:image" content="{{ site.url }}{{ site.image }}" />
    <meta property="og:site_name" content="Refresh DC" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="{{ site.twitter.site }}" />
    <meta name="twitter:title" content="{{ pageTitle }}" />
    <meta name="twitter:description" content="{{ pageDescription }}" />
    <meta name="twitter:image" content="{{ site.url }}{{ site.image }}" />

    <link rel="canonical" href="{{ site.url }}{{ page.url }}" />

    <!-- JSON-LD -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Refresh DC",
      "url": "https://refresh-dc.org/",
      "logo": "https://refresh-dc.org/assets/images/refresh_dc_logo.png",
      "description": "A Washington, DC community bringing together designers, developers, strategists, writers, and entrepreneurs at the intersection of creativity and technology since 2006.",
      "foundingDate": "2006",
      "areaServed": {
        "@type": "City",
        "name": "Washington, DC"
      },
      "knowsAbout": ["Design", "Technology", "Creative Strategy", "Web Development"],
      "sameAs": [
        "https://www.instagram.com/refreshdc",
        "https://www.linkedin.com/company/refresh-dc",
        "https://www.youtube.com/@refreshdc",
        "https://x.com/refreshdc",
        "https://www.eventbrite.com/o/refresh-dc-1039770801"
      ],
      "event": {
        "@type": "EventSeries",
        "name": "Refresh DC Meetups",
        "description": "Talks, hands-on workshops, and networking events for DC's creative and tech communities."
      }
    }
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Styles -->
    <link rel="stylesheet" href="/assets/css/styles.css" />

    <!-- Alpine.js for interactivity -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  </head>
  <body  >
    {% include "components/navbar.njk" %}
    <main>
      {{ content | safe }}
    </main>
    {% include "components/footer.njk" %}
  </body>
</html>
