<section class="py-16 lg:py-24 bg-rf-grey">
  <div class="max-w-screen-xl mx-auto px-5">
    <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight text-rf-blue text-center">
      Stay Updated
    </h2>
    <p class="mt-3 text-lg text-rf-blue/70 text-center">Subscribe to get the latest Refresh DC news delivered to your inbox.</p>

    <form
      action="https://refresh-dc.us10.list-manage.com/subscribe/post?u=09b9eff2e09e315510cf2c7e6&amp;id=9ada04feba&amp;f_id=000c4be4f0"
      method="post"
      id="mc-embedded-subscribe-form"
      name="mc-embedded-subscribe-form"
      class="validate mt-8"
      target="_self"
      novalidate=""
    >
      <div class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto">
        <label for="mce-EMAIL" class="sr-only">Email Address</label>
        <input
          type="email"
          name="EMAIL"
          id="mce-EMAIL"
          required=""
          value=""
          placeholder="your@email.com"
          class="required email flex-1 rounded-lg border border-rf-blue/20 bg-white px-4 py-3 text-rf-blue placeholder-rf-blue/40 focus:outline-none focus:ring-2 focus:ring-rf-blue"
        >
        <button
          type="submit"
          name="subscribe"
          id="mc-embedded-subscribe"
          class="rounded-lg bg-rf-blue px-6 py-3 font-semibold text-white hover:bg-rf-blue/90 transition-colors"
        >
          Subscribe
        </button>
      </div>

      <!-- Mailchimp bot protection — do not remove -->
      <div style="position: absolute; left: -5000px;" aria-hidden="true">
        <input type="text" name="b_09b9eff2e09e315510cf2c7e6_9ada04feba" tabindex="-1" value="">
      </div>

      <div id="mce-responses" class="mt-4">
        <div class="response text-red-600 text-sm" id="mce-error-response" style="display: none;"></div>
        <div class="response text-rf-green text-sm" id="mce-success-response" style="display: none;"></div>
      </div>
    </form>
  </div>
</section>
