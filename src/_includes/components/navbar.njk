      </a>
      <div class="block lg:hidden">
        <button @click="open = !open" class="text-white">
          {# Hamburger icon #}
          <svg x-show="!open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          {# Close icon #}
          <svg x-show="open" x-cloak class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    </div>

    {# Mobile menu - hidden by default, shown when open is true #}
    <nav
      x-show="open"
      x-cloak
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0 -translate-y-1"
      x-transition:enter-end="opacity-100 translate-y-0"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="opacity-100 translate-y-0"
      x-transition:leave-end="opacity-0 -translate-y-1"
      class="w-full lg:hidden mt-2"
    >
      <ul class="flex flex-col">
        {% for item in navigation.items %}
          {% if item.children %}
            <li class="relative" x-data="{ dropdownOpen: false }">
              <button @click="dropdownOpen = !dropdownOpen" class="flex items-center gap-1 w-full py-2 text-white hover:text-gray-900">
                <span>{{ item.title }}</span>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3 h-3 mt-0.5 transition-transform" :class="{ 'rotate-180': dropdownOpen }">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
                </svg>
              </button>
              <div x-show="dropdownOpen" x-cloak class="pl-4">
                {% for child in item.children %}
                  <a href="{{ child.path }}" class="block py-1 text-white  hover:text-gray-900">{{ child.title }}</a>
                {% endfor %}
              </div>
            </li>
          {% else %}
            <li>
              <a href="{{ item.path }}" class="flex py-2 items-center text-white  hover:text-gray-900">
                <span>{{ item.title }}</span>
                {% if item.badge %}
                  <span class="ml-1 px-2 py-0.5 text-[10px] animate-pulse font-semibold uppercase text-white bg-indigo-600 rounded-full">New</span>
                {% endif %}
              </a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
     <!-- <div class="flex items-center mt-3 gap-4">
        {{ link("#", "Log in", "muted", "md", true) }}
        {{ link("#", "Sign up", "primary", "md", true) }}
      </div> -->
    </nav>

    {# Desktop menu - always visible on lg screens #}
    <nav class="hidden lg:flex lg:items-center lg:w-auto">
      <ul class="flex flex-row gap-3">
        {% for item in navigation.items %}
          {% if item.children %}
            <li class="relative" x-data="{ dropdownOpen: false }">
              <button @click="dropdownOpen = !dropdownOpen" @click.away="dropdownOpen = false" class="flex items-center gap-1 px-3 py-2 text-white  hover:text-gray-900">
                <span>{{ item.title }}</span>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3 h-3 mt-0.5 transition-transform" :class="{ 'rotate-180': dropdownOpen }">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
                </svg>
              </button>
              <div
                x-show="dropdownOpen"
                x-cloak
                x-transition:enter="transition ease-out duration-100"
                x-transition:enter-start="opacity-0 scale-95"
                x-transition:enter-end="opacity-100 scale-100"
                x-transition:leave="transition ease-in duration-75"
                x-transition:leave-start="opacity-100 scale-100"
                x-transition:leave-end="opacity-0 scale-95"
                class="absolute w-48 z-10 {{ 'right-0 origin-top-right' if loop.last else 'left-0 origin-top-left' }}"
              >
                <div class="mt-2 py-2 bg-white rounded-md shadow-lg border flex flex-col">
                  {% for child in item.children %}
                    <a href="{{ child.path }}" class="px-4 py-1 text-white  hover:text-gray-900 hover:bg-gray-50">{{ child.title }}</a>
                  {% endfor %}
                </div>
              </div>
            </li>
          {% else %}
            <li>
              <a href="{{ item.path }}" class="flex px-3 py-2 items-center text-white  hover:text-gray-900">
                <span>{{ item.title }}</span>
                {% if item.badge %}
                  <span class="ml-1 px-2 py-0.5 text-[10px] animate-pulse font-semibold uppercase text-white bg-indigo-600 rounded-full">New</span>
                {% endif %}
              </a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </nav>

    {# Desktop auth buttons #}
   <!-- <div class="hidden lg:flex items-center gap-4">
      <a href="#" class="text-white  hover:text-gray-900">Log in</a>
      {{ link("#", "Sign up", "primary", "md") }}
    </div> -->
    </div>
  </div>
</header>

<style>
  [x-cloak] { display: none !important; }
</style>
